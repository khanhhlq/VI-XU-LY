#INCLUDE <16F887.H> // KHAI BAO THU VIEN
#FUSES INTRC // XUNG NOI
#USE DELAY(CLOCK=8M)

VOID MAIN(){
   SET_TRIS_D(0X00);
   
   OUTPUT_D(0X00);
   DELAY_MS(1000);

   WHILE(TRUE){
      FOR (INT I = 0; I <=2; I++){
         OUTPUT_D(0XFF);
         DELAY_MS(500);
      }
      OUTPUT_D(0X55);
      DELAY_MS(1000);
   }
}
