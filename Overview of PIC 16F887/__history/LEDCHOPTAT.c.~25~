#INCLUDE <16F887.H> // KHAI BAO THU VIEN
#FUSES INTRC // XUNG NOI
#USE DELAY(CLOCK=8M)
UNSiGNED INT8 I = 0;
UNSiGNED INT8 X = 0;

VOID MAIN(){
   SET_TRIS_D(0X00);
   
   OUTPUT_D(0X00);
   DELAY_MS(1000);

   WHILE(TRUE){
      FOR (I = 0; I <= 7; I++){
         X = (X >> 1) + 0X80;
         OUTPUT_D(X);
         DELAY_MS(500);
      }
      FOR (I = 0; I <= 7; I++){
         X = (X << 1);
         OUTPUT_D(X);
         DELAY_MS(500);
      }
   }
}
