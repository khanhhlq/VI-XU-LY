#INCLUDE <16F887.H>
#FUSES HS, PUT
#USE DELAY(CLOCK=20M)

CONST UNSIGNED CHAR MA7DOAN[10] = {0xC0,0xF9,0xA4,0xB0,0x99,0x92,0x82,0xF8,0x80,0x90};

UNSIGNED INT8 COUNT = 0;

VOID MAIN(){
   SET_TRIS_D(0X00);
   
   WHILE(TRUE){
      OUTPUT_D(MA7DOAN[COUNT];
      COUNT++;
      DELAY_MS(500);
   }
}
