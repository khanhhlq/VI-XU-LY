#INCLUDE <16F887.H>
#FUSES HS, PUT, NOWDT, NOLVP, NOPROTECT
#USE DELAY(CLOCK=20M)

#define LCD_ENABLE_PIN  PIN_D0
#define LCD_RS_PIN      PIN_D1
#define LCD_RW_PIN      PIN_D2
#define LCD_DATA4       PIN_D4
#define LCD_DATA5       PIN_D5
#define LCD_DATA6       PIN_D6
#define LCD_DATA7       PIN_D7
#define ON_OFF          PIN_E0
#define CHANNEL         PIN_E1

#INCLUDE <LCD.C>

CONST UNSIGNED CHAR MA7DOAN[10] = {0xC0,0xF9,0xA4,0xB0,0x99,0x92,0x82,0xF8,0x80,0x90}; // mang led 7 doan

INT1 STATUS = 1; // ON/OFF
UNSIGNED INT8 MODE = 1; // CHANNEL

VOID MAIN(){
   SET_TRIS_D(0);
   SET_TRIS_E(0XFF);
   
   LCD_INIT();
   LCD_GOTOXY(6,1);
   LCD_PUTC("NHAN ON");
   LCD_GOTOXY(4,2);
   LCD_PUTC("DE BAT DAU");
   
   WHILE(TRUE){
      IF (!INPUT(ON_OFF)){
         STATUS = ~STATUS;
      }
      
      IF (!STATUS){
         IF (!INPUT(CHANNEL)){
            OUTPUT_B(MA7DOAN[MODE]);
            MODE++;
         }
      }
      ELSE {
         LCD_INIT();
         LCD_GOTOXY(6,1);
         LCD_PUTC("NHAN ON");
         LCD_GOTOXY(4,2);
         LCD_PUTC("DE BAT DAU");
      }
   }

}
