.................... void lcd_putc(char c) 
.................... { 
....................    switch (c) 
0135:  MOVF   28,W
0136:  XORLW  07
0137:  BTFSC  03.2
0138:  GOTO   143
0139:  XORLW  0B
013A:  BTFSC  03.2
013B:  GOTO   148
