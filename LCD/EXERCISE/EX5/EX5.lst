0146:  MOVWF  2A
0147:  MOVWF  2B
0148:  CALL   125
0149:  GOTO   162
....................  
....................       case '\f'   :  lcd_send_byte(0,1); 
014A:  CLRF   2E
014B:  MOVLW  01
014C:  MOVWF  2F
014D:  CALL   081
....................                      delay_ms(2); 
014E:  MOVLW  02
