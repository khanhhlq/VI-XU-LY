VOID MAIN(){
   SET_TRIS_D(0);
   SET_TRIS_E(0);
   
   LCD_INIT();
   
  WHILE(TRUE){
     GIAY++;
     DELAY_MS(200);
     
     IF (GIAY > 59){
        PHUT++;
        GIAY = 0;
     }
     
     IF (PHUT > 59){
        GIO++;
        PHUT = 0;
     }
     
     IF (GIO > 24) GIO = 0;
     
     LCD_GOTOXY(1,1);
     LCD_PUTC("SECOND COUNTER");
     LCD_GOTOXY(1,2);
     PRINTF(LCD_PUTC, "%02U", GIO);
     LCD_GOTOXY(6,2);
     PRINTF(LCD_PUTC, "%02U", PHUT);
     LCD_GOTOXY(11,2);
     PRINTF(LCD_PUTC, "%02U", GIAY);
  }
}
