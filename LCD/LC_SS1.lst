....................                     #endif 
....................                      break; 
014B:  GOTO   15C
....................  
....................      #if defined(LCD_EXTENDED_NEWLINE) 
....................       case '\r'   :  lcd_gotoxy(1, g_LcdY+1);   break; 
....................       case '\n'   : 
....................          while (g_LcdX++ < LCD_LINE_LENGTH) 
....................          { 
....................             lcd_send_byte(1, ' '); 
....................          } 
....................          lcd_gotoxy(1, g_LcdY+2); 
....................          break; 
....................      #else 
....................       case '\n'   : lcd_gotoxy(1,2);        break; 
014C:  MOVLW  01
014D:  MOVWF  26
014E:  MOVLW  02
014F:  MOVWF  27
0150:  CALL   11F
0151:  GOTO   15C
....................      #endif 
....................       
